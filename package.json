{
  "name": "strapi-plugin-quick-filters",
  "version": "0.1.0",
  "description": "Quick pill-select filters for Content Manager list view relation fields",
  "license": "MIT",
  "author": {
    "name": "Tuan Pham"
  },
  "strapi": {
    "kind": "plugin",
    "name": "quick-filters",
    "displayName": "Quick Filters",
    "description": "Quick pill-select filters for Content Manager list view relation fields"
  },
  "exports": {
    "./strapi-admin": {
      "source": "./admin/src/index.tsx",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "verify": "strapi-plugin verify"
  },
  "dependencies": {
    "qs": "^6.11.0"
  },
  "devDependencies": {
    "@strapi/sdk-plugin": "^5.3.2",
    "@strapi/strapi": "^5.50.2",
    "@strapi/design-system": "^2.0.0",
    "@strapi/icons": "^2.0.0",
    "@types/qs": "^6.9.15",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@strapi/strapi": "^5.0.0",
    "@strapi/design-system": "^2.0.0",
    "@strapi/icons": "^2.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  }
}
